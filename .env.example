TZ=Asia/Hong_Kong

# change these before production use
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=second_hand_trading
MYSQL_USER=trading
MYSQL_PASSWORD=change-me-app-password

# public URL used in uploaded image links, keep the /api suffix out
# examples:
#   http://your-server-ip
#   https://demo.example.com
PUBLIC_BASE_URL=http://your-server-ip

# domain / https automation
DOMAIN_NAME=example.com
CERTBOT_EMAIL=admin@example.com
# optional comma-separated list, e.g. example.com,www.example.com
CERTBOT_DOMAINS=

# host port for the web container
HTTP_PORT=80
HTTPS_PORT=443

# optional JVM tuning
JAVA_OPTS=-Xms512m -Xmx1024m
